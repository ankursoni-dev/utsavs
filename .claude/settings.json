{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Hook config for the NestJS multi-agent setup. See .claude/README.md for the architecture.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/SEED-SESSION.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "_comment": "Risk classification — runs BEFORE ENRICH-PROMPT; injects <risk_tier> tag",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/CLASSIFY-RISK.py"
          }
        ]
      },
      {
        "_comment": "Context enrichment — injects relevant wikis + structural summaries based on prompt keywords",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/ENRICH-PROMPT.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "_comment": "Block writes to sensitive files for ALL agents",
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/BLOCK-SECRETS.py"
          }
        ]
      },
      {
        "_comment": "Restrict tester subagent's Bash to test commands only",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/RESTRICT-BASH-TESTER.py"
          }
        ]
      },
      {
        "_comment": "Restrict curator subagent's Write/Edit to .claude/context/ only",
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/.claude/hooks/RESTRICT-WRITE-CURATOR.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "_comment": "Auto-format .ts files after edits (advisory; failures don't block)",
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/AUTO-FORMAT.sh"
          }
        ]
      }
    ]
  }
}
